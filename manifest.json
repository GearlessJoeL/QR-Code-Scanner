{
  "manifest_version": 3,
  "name": "Right-Click QR Scanner",
  "version": "1.0",
  "description": "Right-click an image to scan QR codes.",
  "permissions": ["contextMenus", "scripting", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
